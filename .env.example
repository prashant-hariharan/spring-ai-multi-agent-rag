# Copy this file to .env and fill real values.
# .env is ignored by git.

# LiteLLM proxy auth key (Spring profile `litellm` should use the same value)
LITELLM_MASTER_KEY=sk-litellm-dev

# Upstream provider keys consumed by LiteLLM
OPEN_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional override for Spring profile if needed
LITELLM_BASE_URL=http://localhost:4000

# Spring datasource (JDBC format used by the app)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ai_ecommerce
SPRING_DATASOURCE_USERNAME=<username>
DB_PASSWORD=<password>

# LiteLLM datasource (Prisma/Postgres URL format used by LiteLLM)
DATABASE_URL=postgresql://<username>:<password>@postgres-pgvector:5432/litellm
